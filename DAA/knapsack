#include <stdio.h>

struct item {
    int weight;
    int profit;
    float ppw;
};

void sort(struct item items[], int n) {
    struct item temp;
    for(int i = 0; i < n - 1; i++) {
        for(int j = 0; j < n - i - 1; j++) {
            if(items[j].ppw < items[j + 1].ppw) {
                temp = items[j];
                items[j] = items[j + 1];
                items[j + 1] = temp;
            }
        }
    }
}

int main() {
    int n, cp;
    float totalprofit = 0;

    printf("Enter number of items: ");
    scanf("%d", &n);

    struct item itm[n];

    printf("Enter knapsack capacity: ");
    scanf("%d", &cp);

    printf("Enter weight and profit of items:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d %d", &itm[i].weight, &itm[i].profit);
        itm[i].ppw = (float)itm[i].profit / itm[i].weight;
    }

    sort(itm, n);

    for(int i = 0; i < n; i++) {
        if(itm[i].weight <= cp) {
            cp -= itm[i].weight;
            totalprofit += itm[i].profit;
        } else {
            totalprofit += itm[i].ppw * cp;
            break;
        }
    }

    printf("Maximum profit = %.2f\n", totalprofit);

    return 0;
}
